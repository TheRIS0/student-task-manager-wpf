<Window x:Class="StudentTaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Task Manager"
        Height="450"
        Width="640"
        WindowStartupLocation="CenterScreen"
        MinHeight="350"
        MinWidth="500">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Tasks"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <ComboBox ItemsSource="{Binding FilterOptions}"
                      SelectedIndex="{Binding SelectedFilterIndex, Mode=TwoWay}"
                      MinWidth="100"
                      VerticalAlignment="Center" />
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding FilteredTasks}"
                 SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                 Margin="0,0,0,12"
                 MinHeight="120">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button Content="Add"
                    Command="{Binding AddTaskCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    MinWidth="70" />
            <Button Content="Edit"
                    Command="{Binding EditTaskCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    MinWidth="70" />
            <Button Content="Delete"
                    Command="{Binding DeleteTaskCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    MinWidth="70" />
            <Button Content="Refresh"
                    Command="{Binding LoadTasksCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    MinWidth="70" />
            <Button Content="Toggle completion"
                    Command="{Binding ToggleCompletionCommand}"
                    Padding="12,6"
                    MinWidth="120" />
        </StackPanel>
    </Grid>
</Window>
