<Window x:Class="StudentTaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Task Manager"
        Height="480"
        Width="660"
        WindowStartupLocation="CenterScreen"
        MinHeight="380"
        MinWidth="520"
        Background="#F0F0F0">
    <Window.Resources>
        <Style x:Key="HeaderTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="76" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.65" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,14"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Tasks"
                           Style="{StaticResource HeaderTitle}"
                           Margin="0,0,16,0" />
                <Label Grid.Column="1"
                       Content="Filter"
                       Target="{Binding ElementName=FilterComboBox}"
                       FontSize="12"
                       Foreground="#666666"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       HorizontalAlignment="Right" />
                <ComboBox x:Name="FilterComboBox"
                          Grid.Column="2"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedIndex="{Binding SelectedFilterIndex, Mode=TwoWay}" />
            </Grid>
        </Border>

        <!-- Task list and actions card -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding FilteredTasks}"
                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0,4,0,4"
                         MinHeight="160"
                         Margin="0,0,0,12">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,10" />
                            <Setter Property="Margin" Value="0,0,0,2" />
                            <Setter Property="Background" Value="#FAFAFA" />
                            <Setter Property="BorderBrush" Value="#EEEEEE" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E8EEF4" />
                                    <Setter Property="BorderBrush" Value="#B0BEC5" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"
                                       ToolTip="{Binding Title}"
                                       FontSize="13"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                <Setter Property="Foreground" Value="#888888" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="Add"
                            Command="{Binding AddTaskCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Edit"
                            Command="{Binding EditTaskCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Delete"
                            Command="{Binding DeleteTaskCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Refresh"
                            Command="{Binding LoadTasksCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Toggle completion"
                            Command="{Binding ToggleCompletionCommand}"
                            MinWidth="120" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
